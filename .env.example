# ==============================================================
# multi-llm-rotator — Environment Variables
# Copy this file to .env and fill in your actual API keys.
# Never commit your real .env file to version control!
# ==============================================================

# --- Gemini (Google AI Studio) ---
# Get keys at: https://aistudio.google.com/app/apikey
GEMINI_KEY_1=AIza...
GEMINI_KEY_2=AIza...
GEMINI_KEY_3=AIza...
# Add more as needed: GEMINI_KEY_4, GEMINI_KEY_5, ...

# --- Claude (Anthropic) ---
# Get keys at: https://console.anthropic.com/
CLAUDE_KEY_1=sk-ant-...
CLAUDE_KEY_2=sk-ant-...
CLAUDE_KEY_3=sk-ant-...
# Add more as needed: CLAUDE_KEY_4, CLAUDE_KEY_5, ...

# --- OpenAI / ChatGPT ---
# Get keys at: https://platform.openai.com/api-keys
OPENAI_KEY_1=sk-...
OPENAI_KEY_2=sk-...
OPENAI_KEY_3=sk-...
# Add more as needed: OPENAI_KEY_4, OPENAI_KEY_5, ...
